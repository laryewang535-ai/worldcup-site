# ========== 赛程 / 比分（服务端读取，勿使用 NEXT_PUBLIC_ 暴露密钥）==========
#
# 【最简单】只填一个 HTTPS 地址：返回 JSON 数组，每项形状见 lib/types.ts 的 MatchRecord
# 自建 BFF / CDN 静态文件均可；保存后请重启 npm run dev
#
# 这里填写一个返回赛程 JSON 数组的 HTTPS 地址。每个元素需符合 lib/types.ts 里的 MatchRecord 结构，例如：
# [
#   {
#     "id": "m-001",
#     "homeId": "united-states",
#     "awayId": "mexico",
#     "kickoffUtc": "2026-06-11T22:00:00.000Z",
#     "stage": "Group A · Matchday 1",
#     "status": "Full Time",
#     "homeScore": 2,
#     "awayScore": 1,
#     "events": ["12' — Early goal", "58' — Leveler", "84' — Decisive finish"],
#     "featured": true
#   }
# ]
MATCHES_FEED_URL=
#
# 若该地址需要鉴权，再填下面一行（完整值，例如：Bearer sk_xxx）
# MATCHES_FEED_AUTHORIZATION=
#
# ---------- 备选：无自建接口时，用 football-data.org（注册后拿 Token）----------
# FOOTBALL_DATA_KEY=
# FOOTBALL_DATA_COMPETITION_CODE=WC
#
# ---------- 定时生成 public/matches.json（npm run sync:matches）----------
# 脚本每 180 秒从 football-data 拉取一次并写入 public/matches.json
# MATCHES_SYNC_INTERVAL_SECONDS=180
# MATCHES_OUTPUT_PATH=public/matches.json
# 本地若使用脚本生成的静态文件，可设置：
# MATCHES_FEED_URL=http://localhost:3000/matches.json
#
# ---------- 缓存（服务端内存，减轻 BFF / football-data 压力）----------
# 外网拉取成功后的复用时间（秒），默认 180（3 分钟），与比分页轮询周期一致
# MATCHES_CACHE_TTL_SECONDS=180
#
# ---------- 其它 ----------
# 强制只用仓库内演示数据（不接外网）
# MATCH_DATA_SOURCE=mock
#
# 兼容旧名（与 MATCHES_FEED_URL 二选一即可，不必同时填）
# MATCHES_JSON_URL=

# ========== 首页倒计时（可选）==========
# NEXT_PUBLIC_COUNTDOWN_TARGET_ISO=

# ========== 站点公开 URL（建议填写，用于 sitemap / robots）==========
# 例如 Vercel 部署：https://worldcup-site-two.vercel.app
# NEXT_PUBLIC_SITE_URL=

# ========== Google AdSense（可选）==========
# 使用「自动广告」时无需配置 slot；ads.txt 已放在 public/ads.txt
# 仅在使用手动展示广告单元时填写 data-ad-slot
# NEXT_PUBLIC_ADSENSE_SLOT=

# ========== Amazon 联盟营销（可选）==========
# 在 Amazon Associates 获取 Tracking ID 后填入；未配置时不展示联盟商品与导流条
# 将 lib/data/gear.ts 中各商品的 asin 替换为真实 ASIN
# NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=
